# =========================
# LangSmith configuration
# =========================
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=prompt-engineering-challenge

# Prompt Hub source/target
LANGSMITH_PROMPT_SOURCE=leonanluppi/bug_to_user_story_v1
LANGSMITH_PROMPT_TARGET=initialhandle/bug_to_user_story_v2
LANGSMITH_PROMPT_PUBLIC=true

# =========================
# Model resolution strategy
# =========================
# Fixed sequence: 1) Ollama, 2) OpenAI, 3) Gemini.

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# OpenAI fallback (used only if Ollama is unavailable)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EVAL_MODEL=gpt-4o

# Gemini fallback (used only if Ollama and OpenAI are unavailable)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EVAL_MODEL=gemini-2.5-flash

# =========================
# Runtime and evaluation
# =========================
TEMPERATURE=0
MAX_ITERATIONS=5
MIN_METRIC_THRESHOLD=0.9

# heuristic | llm | hybrid
EVAL_MODE=heuristic

# Default prompt file evaluated by src/evaluate.py
PROMPT_FILE=prompts/bug_to_user_story_v2.yml
